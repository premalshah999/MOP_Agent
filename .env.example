APP_VERSION=0.1.0
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_SECONDS=86400
SQLITE_DB_PATH=data/runtime/mop.sqlite3
DUCKDB_PATH=data/runtime/mop.duckdb
MAX_RETURN_ROWS=250
QUERY_TIMEOUT_SECONDS=15
DEBUG_ERRORS=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
TRUSTED_HOSTS=127.0.0.1,localhost,testserver

# Optional: set ASSISTANT_ROUTER_MODE=llm and OPENAI_API_KEY to route broad
# conversational messages with an LLM. The local semantic router remains the
# safe offline fallback.
ASSISTANT_ROUTER_MODE=local
ASSISTANT_ROUTER_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
