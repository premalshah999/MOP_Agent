APP_VERSION=0.1.0
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_SECONDS=86400
SQLITE_DB_PATH=data/runtime/mop.sqlite3
DUCKDB_PATH=data/runtime/mop.duckdb
MAX_RETURN_ROWS=250
QUERY_TIMEOUT_SECONDS=15
DEBUG_ERRORS=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
TRUSTED_HOSTS=127.0.0.1,localhost,testserver

# REQUIRED. The pipeline is LLM-grounded text-to-SQL (intent -> routing ->
# retrieval -> SQL generation -> grounded answer -> faithfulness judge).
# DEEPSEEK_API_KEY (DeepSeek, OpenAI-compatible) must be set for live answers.
# Without a key the app boots but every analytical question fails safe to a
# clarification prompt, and the strict eval / live stage tests self-skip.
ASSISTANT_ROUTER_BASE_URL=https://api.deepseek.com
ASSISTANT_ROUTER_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
# Fallback provider (used only if DEEPSEEK_API_KEY is empty):
OPENAI_API_KEY=

# LLM client tuning (optional):
# LLM_TIMEOUT=60   LLM_RETRIES=2
# LLM_MODE=fixture  -> force recorded-fixture replay (offline determinism)
# LLM_RECORD=1      -> when live, save responses as fixtures for offline CI
