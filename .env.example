LLM_PROVIDER=gemini
LLM_MODEL=gemini-flash-latest
LLM_REASONER_MODEL=gemini-flash-latest
LLM_TIMEOUT=45

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
GEMINI_REASONER_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=45

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT=45
APP_VERSION=1.0.0

# Authentication
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_SECONDS=86400

# Database
SQLITE_DB_PATH=data/runtime/mop.sqlite3
DUCKDB_PATH=data/runtime/mop.duckdb

# SQL agent
SQL_MAX_TOKENS=1400
SQL_REPAIR_ATTEMPTS=3
SQL_REPAIR_MODELS=
SQL_PREFLIGHT_ENABLED=1
FORMATTER_MAX_TOKENS=4000
CONCEPTUAL_MAX_TOKENS=1800
MIN_ANALYTIC_WORDS=150
FORMATTER_PREVIEW_ROWS=60
MAX_RETURN_ROWS=250
DEFAULT_TOP_K=15
MAX_TOP_K=50

# Server
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=127.0.0.1,localhost,testserver
GZIP_MINIMUM_SIZE=1000
UVICORN_WORKERS=1
LOG_LEVEL=info
