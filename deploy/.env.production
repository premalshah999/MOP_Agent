# =============================================================================
# MOP Agent — Production environment template
# =============================================================================
# Copy this to /opt/mop-agent/.env on the Hetzner server.
# Never commit the real .env — it contains secrets.
# =============================================================================

# ── REQUIRED — fill these in ─────────────────────────────────────────────────

# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-hex-chars

# ── LLM settings ─────────────────────────────────────────────────────────────

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT=45

# ── App version ──────────────────────────────────────────────────────────────

APP_VERSION=1.0.0

# ── Auth ─────────────────────────────────────────────────────────────────────

JWT_EXPIRY_SECONDS=86400

# ── Databases (paths inside the Docker container) ────────────────────────────
# These are mounted on a persistent Docker volume (mop-data).
# Do NOT change these unless you change the Docker volume mount too.

SQLITE_DB_PATH=/app/data/runtime/mop.sqlite3
DUCKDB_PATH=/app/data/runtime/mop.duckdb

# ── SQL agent tuning ─────────────────────────────────────────────────────────

SQL_MAX_TOKENS=1400
SQL_REPAIR_ATTEMPTS=3
SQL_REPAIR_MODELS=deepseek-chat,deepseek-reasoner
SQL_PREFLIGHT_ENABLED=1
RESULT_VALIDATION_ENABLED=1
STRUCTURED_SQL_ENABLED=1

# ── Answer formatting ────────────────────────────────────────────────────────

FORMATTER_MAX_TOKENS=4000
CONCEPTUAL_MAX_TOKENS=1800
MIN_ANALYTIC_WORDS=150
FORMATTER_PREVIEW_ROWS=60
MAX_RETURN_ROWS=250
DEFAULT_TOP_K=15
MAX_TOP_K=50

# ── CORS & trusted hosts ─────────────────────────────────────────────────────
# After Vercel deployment, set ALLOWED_ORIGINS to your Vercel URL:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
# Multiple origins: comma-separated, no spaces.
# Use * only for testing — never in production.

ALLOWED_ORIGINS=https://your-app.vercel.app
TRUSTED_HOSTS=your-domain.com,localhost,127.0.0.1

# ── Server ───────────────────────────────────────────────────────────────────

GZIP_MINIMUM_SIZE=1000
UVICORN_WORKERS=1
LOG_LEVEL=info
